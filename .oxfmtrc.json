{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "semi": true,
    "arrowParens": "avoid",
    "singleQuote": true,
    "tabWidth": 4,
    "printWidth": 100,
    "bracketSpacing": true,
    "htmlWhitespaceSensitivity": "ignore",
    "sortPackageJson": false,
    "ignorePatterns": ["pnpm-lock.yaml"]
}

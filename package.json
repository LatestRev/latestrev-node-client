{
    "name": "@latestrev/node-client",
    "version": "2.1.3",
    "description": "LatestRev.com Node.js client",
    "main": "./index.js",
    "type": "module",
    "packageManager": "pnpm@11.5.2",
    "exports": {
        ".": {
            "import": "./index.js",
            "require": "./index.js"
        }
    },
    "files": [
        "index.js",
        "src/",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "test": "vitest run",
        "test:watch": "vitest",
        "format": "oxfmt --write .",
        "format:check": "oxfmt --check .",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/LatestRev/latestrev-node-client.git"
    },
    "keywords": [
        "latestrev",
        "cms",
        "headless",
        "json"
    ],
    "author": "LatestRev",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/LatestRev/latestrev-node-client/issues"
    },
    "homepage": "https://github.com/LatestRev/latestrev-node-client#readme",
    "dependencies": {
        "@thinkpixellab-public/px-long-operations": "^2.1.0",
        "undici": "^8.0.0"
    },
    "devDependencies": {
        "oxfmt": "^0.53.0",
        "oxlint": "^1.68.0",
        "vite": "^7.0.0",
        "vitest": "^4.1.4"
    }
}
